  initial_protection_ms: 120
  energy_threshold: 650
  pipeline_min_ms: 55
  pipeline_energy_threshold: 160
  greeting_protection_ms: 2400
  pipeline_barge_rms_ema_alpha: 0.38
  pipeline_barge_silent_decay_ratio: 0.22
  talk_detect_initial_protection_ms: 350
