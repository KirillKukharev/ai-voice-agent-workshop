# --- Инфраструктура (см. README «Переменные окружения») ---
INIT_TIMEOUT=180
TZ=America/Montreal
XIVO_UUID=00000000-0000-4000-8000-0000000AA450
LOCAL_GIT_REPOS=/path/to/parent-of-wazo-auth-keys-and-xivo-config

# --- Yandex Cloud (SpeechKit STT/TTS, IAM) ---
YANDEX_SERVICE_ACCOUNT_ID=
YANDEX_SA_KEY_ID=
YANDEX_PRIVATE_KEY=
YANDEX_FOLDER_ID=

# --- Связка бота с сервисом распознавания (Bearer = APP_TOKEN у speech_to_text в docker-compose) ---
STT_TOKEN=

# --- LLM (Dify / nocode) ---
NOCODE_BASE_URL=https://example.com
NOCODE_API_KEY=

# --- OpenAI (если используете в коде / другие сценарии) ---
OPENAI_API_KEY=

# --- Airtable (опционально: брони, тикеты) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TICKETS_TABLE=
AIRTABLE_BOOKINGS_TABLE=

# --- Модели (переопределяют дефолты в приложении) ---
STT_MODEL=gigaam
TTS_MODEL=yandex

# --- Wazo Auth (REST, не путать с паролем UI до настройки) ---
WAZO_AUTH_USERNAME=root
WAZO_AUTH_PASSWORD=

# --- Зарезервировано / внешний Asterisk (в compose ARI задаётся через environment сервиса wazo-ai-bot) ---
ASTERISK_HOST=
ASTERISK_ARI_PORT=
ASTERISK_ARI_USER=
ASTERISK_ARI_PASSWORD=
ARI_APP_NAME=
